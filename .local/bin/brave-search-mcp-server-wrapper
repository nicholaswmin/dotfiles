#!/bin/bash
export PATH="/opt/homebrew/bin:$PATH"
eval "$(fnm env 2>/dev/null)" 2>/dev/null
BRAVE_API_KEY="$(security find-generic-password -s brave -w "$HOME/Library/Keychains/environment.keychain-db")" || {
  echo "brave-search wrapper: 'brave' secret not in the environment keychain" >&2
  exit 1
}
export BRAVE_API_KEY
exec npx -y @brave/brave-search-mcp-server --transport stdio "$@"
