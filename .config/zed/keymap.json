[
  {
    "bindings": {
      "cmd-p": "command_palette::Toggle",
      "cmd-j": "project_panel::ToggleFocus",
      "cmd-o": "workspace::AddFolderToProject",
      "cmd-q": "pane::CloseActiveItem",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "cmd-j": "project_panel::ToggleFocus",
      "ctrl-alt-cmd-right": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "OutlinePanel && not_editing",
    "bindings": {
      "cmd-j": "project_panel::ToggleFocus",
      "ctrl-alt-cmd-right": "outline_panel::ToggleFocus",
    },
  },
  {
    "bindings": {
      "shift-cmd-o": "workspace::AddFolderToProject",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-shift-o": "workspace::Open",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-tt": "terminal_panel::Toggle",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-n": "workspace::NewFile",
      "cmd-t": "terminal_panel::Toggle",
      "cmd-j": "outline_panel::ToggleFocus",
      "ctrl-alt-cmd-up": "terminal_panel::Toggle",
      "ctrl-alt-cmd-left": "agent::ToggleFocus",
      "escape": "editor::Cancel",
    },
  },
  {
    "context": "OutlinePanel > Editor && mode == single_line",
    "bindings": {
      "cmd-j": "project_panel::ToggleFocus",
      "ctrl-alt-cmd-right": "outline_panel::ToggleFocus",
    },
  },
  {
    "context": "ProjectPanel > Editor && mode == single_line",
    "bindings": {
      "cmd-j": "project_panel::ToggleFocus",
      "ctrl-alt-cmd-right": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "Workspace && !Terminal",
    "bindings": {
      "ctrl-alt-cmd-down": "terminal_panel::Toggle",
    },
  },
  {
    "context": "Workspace && !AgentPanel",
    "bindings": {
      "ctrl-alt-cmd-right": "agent::ToggleFocus",
    },
  },
  {
    "context": "AgentPanel",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-alt-cmd-up": "editor::ToggleFocus",
      "ctrl-alt-cmd-down": "terminal_panel::Toggle",
      "ctrl-alt-cmd-left": "workspace::ActivatePaneLeft",
      "ctrl-alt-cmd-right": "workspace::CloseActiveDock",
    },
  },
  {
    "context": "AgentPanel && acp_thread",
    "bindings": {
      "cmd-t": "agent::NewThread",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-alt-cmd-up": "workspace::ActivatePaneUp",
      "ctrl-alt-cmd-down": "terminal_panel::Toggle",
      "ctrl-alt-cmd-left": "outline_panel::ToggleFocus",
      "cmd-q": "pane::CloseActiveItem",
      "tab": ["terminal::SendText", "\u0009"],
      "cmd-n": "workspace::NewTerminal",
      "cmd-t": "workspace::NewTerminal",
    },
  },
  {
    "context": "Editor && extension == md",
    "bindings": {
      "cmd-m": "markdown::OpenPreview",
    },
  },
  {
    "context": "MarkdownPreview",
    "bindings": {
      "cmd-m": "pane::CloseActiveItem",
    },
  },
  {
    "context": "SettingsWindow",
    "bindings": {
      "cmd-m": null,
    },
  },
  {
    "context": "AgentPanel && text_thread",
    "bindings": {
      "cmd-t": "agent::NewThread",
    },
  },
  {
    "context": "ProjectSearchBar > Editor",
    "bindings": {
      "cmd-j": null,
    },
  },
  {
    "context": "BufferSearchBar > Editor",
    "bindings": {
      "cmd-j": null,
    },
  },
  {
    "context": "Picker > Editor",
    "bindings": {
      "cmd-j": null,
    },
  },
  {
    "context": "FileFinder || (FileFinder > Picker > Editor) || (FileFinder > Picker > menu)",
    "bindings": {
      "cmd-j": "pane::SplitDown",
    },
  },
  {
    "context": "GitPanel && CommitEditor > Editor",
    "bindings": {
      "cmd-j": "git_panel::ToggleFocus",
    },
  },
  {
    "context": "BufferSearchBar",
    "bindings": {
      "escape": "buffer_search::Dismiss",
    },
  },
  {
    "context": "Picker",
    "bindings": {
      "escape": "menu::Cancel",
    },
  },
  {
    "bindings": {
      "cmd-g": "git_panel::Toggle",
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "cmd-g": "project_panel::Toggle",
    },
  },
]
